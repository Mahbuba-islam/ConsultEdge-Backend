# Nginx reverse proxy for ConsultEdge backend
# Save to /etc/nginx/sites-available/consultedge and symlink to sites-enabled.
# Replace api.yourdomain.com with your real domain, then run:
#   sudo certbot --nginx -d api.yourdomain.com

server {
    listen 80;
    listen [::]:80;
    server_name api.yourdomain.com;

    # File upload size limit (matches multer 10MB, leave headroom)
    client_max_body_size 15M;

    # Long timeouts for Socket.IO / WebSocket
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Required for Socket.IO and raw WebSocket (/ws/chat)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
