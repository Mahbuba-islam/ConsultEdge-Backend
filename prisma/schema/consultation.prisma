model Consultation {
    id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

    videoCallId   String             @unique @db.Uuid()
    status        ConsultationStatus @default(PENDING)
    paymentStatus PaymentStatus      @default(UNPAID)

    date DateTime

    startedAt        DateTime?
    endedAt          DateTime?
    cancelledAt      DateTime?
    cancelReason     String?
    cancelledBy      Role?
    rescheduledAt    DateTime?
    rescheduleReason String?
    rescheduledBy    Role?
    sessionSummary   String?

    // Relations
    clientId String @db.Uuid
    client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

    expertScheduleId String         @unique @db.Uuid
    expertSchedule   ExpertSchedule @relation("ExpertScheduleToConsultation", fields: [expertScheduleId], references: [id])

    payment     Payment?
    testimonial Testimonial?
    chatRooms   ChatRoom[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    expert    Expert?  @relation(fields: [expertId], references: [id])
    expertId  String?  @db.Uuid

    @@index([clientId])
    @@index([expertScheduleId])
    @@index([status])
    @@map("consultations")
}
