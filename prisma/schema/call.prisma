model Call {
	id     String   @id @default(uuid())
	roomId String
	room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

	status    CallStatus @default(PENDING)
	startedAt DateTime?
	endedAt   DateTime?
	createdAt DateTime   @default(now())

	participants CallParticipant[]

	@@index([roomId])
	@@map("calls")
}
