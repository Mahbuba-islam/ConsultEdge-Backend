model ExpertSchedule {
    id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

    expertId String @db.Uuid
    expert   Expert @relation(fields: [expertId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    scheduleId String   @db.Uuid
    schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    consultationId String?       @db.Uuid
    consultation   Consultation? @relation("ExpertScheduleToConsultation")

    isBooked    Boolean @default(false)
    isPublished Boolean @default(false)
    isDeleted   Boolean @default(false)
    deletedAt   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([expertId, scheduleId])
    @@index([expertId])
    @@index([scheduleId])
    @@map("expert_schedules")
}
