<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google log in</title>
</head>
<body>
    <div>
        <p>
            Redirecting to google..........
        </p>
    </div>
</body>
<script>
    (
        async()=>{
            try{
       const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
        method:"POST",
        headers:{
            "Content-Type": "application/json"
        },
      body:JSON.stringify({
        provider: "google",
        callbackURL: "<%= callbackURL %>"
      })

    
       })
         const data = await response.json()
         if(data.url){
            window.location.href= data.url
         }

         else{
              document.body.innerHTML = `<div><p>Error Occured While Redirecting to Google. please try again later</p></div>`
         }
            }
            catch(error){
                document.body.innerHTML = `<div><p>Error Occured While Redirecting to Google. please try again later</p></div>`
                {error.message}
            }
        }
    )()
</script>
</html>